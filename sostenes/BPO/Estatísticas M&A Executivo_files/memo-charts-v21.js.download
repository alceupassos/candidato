/* Charts — Memorando de Investimento v2.1 (aporte R$ 230 mil, breakeven M6)
   Vanilla SVG, axis-labelled, single-axis per chart. Values in R$ mil. */

(function () {
  var MONTHS = ['M1','M2','M3','M4','M5','M6','M7','M8','M9','M10','M11','M12'];
  var RESULTADO = [-38.0, -55.1, -10.1, -5.4, -0.7, 4.1, 2.7, 7.4, 12.2, 16.9, 16.9, 21.5];
  var CAIXA = [112.0, 56.9, 46.8, 41.4, 40.7, 124.8, 127.5, 134.9, 147.1, 164.0, 180.9, 202.4];

  var INK = '#191c21';
  var SOFT = '#848c99';
  var HAIR = '#d4dae2';
  var NEG = '#8c3b2e';

  function fmt(v) {
    return v.toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 1 });
  }

  /* ---- Chart 1: Resultado mensal (barras) ---- */
  function chartResultado(el) {
    var W = 640, H = 250;
    var padL = 44, padR = 6, padT = 14, padB = 26;
    var yMin = -62, yMax = 28;
    var iw = W - padL - padR, ih = H - padT - padB;
    function y(v) { return padT + ih * (1 - (v - yMin) / (yMax - yMin)); }
    var n = RESULTADO.length;
    var step = iw / n, bw = step * 0.56;

    var s = '<svg viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Resultado mensal do ano 1 em barras">';

    [-60, -40, -20, 0, 20].forEach(function (t) {
      var yy = y(t);
      s += '<line x1="' + padL + '" y1="' + yy + '" x2="' + (W - padR) + '" y2="' + yy + '" stroke="' + (t === 0 ? INK : HAIR) + '" stroke-width="' + (t === 0 ? 1.2 : 1) + '"/>';
      s += '<text x="' + (padL - 8) + '" y="' + (yy + 3.5) + '" text-anchor="end" font-size="10" fill="' + SOFT + '">' + (t > 0 ? '+' + t : t) + '</text>';
    });

    RESULTADO.forEach(function (v, i) {
      var x = padL + i * step + (step - bw) / 2;
      var y0 = y(0), y1 = y(v);
      var top = Math.min(y0, y1), h = Math.abs(y0 - y1);
      var fill = v >= 0 ? 'var(--accent)' : NEG;
      s += '<rect x="' + x.toFixed(1) + '" y="' + top.toFixed(1) + '" width="' + bw.toFixed(1) + '" height="' + Math.max(h, 1).toFixed(1) + '" fill="' + fill + '"/>';
      var ly = v >= 0 ? y1 - 5 : y1 + 11;
      s += '<text x="' + (x + bw / 2).toFixed(1) + '" y="' + ly.toFixed(1) + '" text-anchor="middle" font-size="9" fill="' + (v >= 0 ? INK : NEG) + '">' + (v > 0 ? '+' : '') + fmt(v) + '</text>';
      s += '<text x="' + (padL + i * step + step / 2).toFixed(1) + '" y="' + (H - 8) + '" text-anchor="middle" font-size="9.5" fill="' + SOFT + '">' + MONTHS[i] + '</text>';
    });

    s += '</svg>';
    el.innerHTML = s;
  }

  /* ---- Chart 2: Caixa acumulado (linha) ---- */
  function chartCaixa(el) {
    var W = 640, H = 250;
    var padL = 44, padR = 10, padT = 18, padB = 26;
    var yMin = 0, yMax = 220;
    var iw = W - padL - padR, ih = H - padT - padB;
    function y(v) { return padT + ih * (1 - (v - yMin) / (yMax - yMin)); }
    function x(i) { return padL + (iw / (CAIXA.length - 1)) * i; }

    var s = '<svg viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Caixa acumulado do ano 1 em linha">';

    [0, 50, 100, 150, 200].forEach(function (t) {
      var yy = y(t);
      s += '<line x1="' + padL + '" y1="' + yy + '" x2="' + (W - padR) + '" y2="' + yy + '" stroke="' + (t === 0 ? INK : HAIR) + '" stroke-width="' + (t === 0 ? 1.2 : 1) + '"/>';
      s += '<text x="' + (padL - 8) + '" y="' + (yy + 3.5) + '" text-anchor="end" font-size="10" fill="' + SOFT + '">' + t + '</text>';
    });

    [[0, 'Tranche 1 · +150'], [5, 'Tranche 2 · +80']].forEach(function (m) {
      var xx = x(m[0]);
      s += '<line x1="' + xx + '" y1="' + padT + '" x2="' + xx + '" y2="' + y(0) + '" stroke="' + SOFT + '" stroke-width="1" stroke-dasharray="2 3"/>';
      s += '<text x="' + (xx + 5) + '" y="' + (padT + 8) + '" font-size="9" fill="' + SOFT + '">' + m[1] + '</text>';
    });

    var pts = CAIXA.map(function (v, i) { return x(i).toFixed(1) + ',' + y(v).toFixed(1); }).join(' ');
    s += '<polyline points="' + pts + '" fill="none" stroke="var(--accent)" stroke-width="2"/>';

    CAIXA.forEach(function (v, i) {
      s += '<circle cx="' + x(i).toFixed(1) + '" cy="' + y(v).toFixed(1) + '" r="2.6" fill="var(--accent)"/>';
      if (i === 0 || i === 4 || i === 5 || i === 11) {
        var anchor = i === 11 ? 'end' : 'middle';
        var tx = i === 11 ? x(i) + 2 : x(i);
        var ty = i === 4 ? y(v) + 16 : y(v) - 8;
        s += '<text x="' + tx.toFixed(1) + '" y="' + ty.toFixed(1) + '" text-anchor="' + anchor + '" font-size="9.5" font-weight="600" fill="' + INK + '">' + fmt(v) + '</text>';
      }
      s += '<text x="' + x(i).toFixed(1) + '" y="' + (H - 8) + '" text-anchor="middle" font-size="9.5" fill="' + SOFT + '">' + MONTHS[i] + '</text>';
    });

    s += '</svg>';
    el.innerHTML = s;
  }

  function render() {
    var a = document.getElementById('chart-resultado');
    var b = document.getElementById('chart-caixa');
    if (a) chartResultado(a);
    if (b) chartCaixa(b);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
})();
