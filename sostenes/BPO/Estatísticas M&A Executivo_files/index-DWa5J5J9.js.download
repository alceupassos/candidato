  font-size: ${e=>e.$size}px;
  line-height: 1;
  /* Glyph renders ~2px left of center inside IconButton on macOS Chrome.
     The <i> inherits font-style:italic and the system -apple-system font
     while ::before is anthropicons/normal; something in that combination
     skews the shrink-wrap on macOS. Normalize font-style and pin a 1em
     square so flex parents center a predictable box on every OS. */
  font-style: normal;
  width: 1em;
  height: 1em;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  /* anthropicons is a single-weight icon font and anthropicons.css sets
     font-weight:normal !important on the :before glyph, so font-weight is
     a no-op. Faux-bold via stroke instead — -webkit-text-stroke is
     supported in all engines (Firefox included). */
  ${e=>e.$bold&&"-webkit-text-stroke: 0.04em currentColor;"}
`;function qa({name:e,size:n=14,style:l,className:r,onClick:s,bold:c=!1}){return O.jsx(UN,{className:`ai-${e} ${r||""}`,$size:n,$bold:c,style:l,onClick:s})}const zl={xs:{padding:"4px 8px",fontSize:11,gap:4,iconSize:11,radius:6},sm:{padding:"6px 12px",fontSize:12,gap:5,iconSize:12,radius:8},md:{padding:"8px 16px",fontSize:13,gap:6,iconSize:14,radius:8}},TN=Se.button`
  padding: ${e=>zl[e.$size].padding};
  font-size: ${e=>zl[e.$size].fontSize}px;
  font-family: inherit;
  font-weight: 500;
  border-radius: ${e=>zl[e.$size].radius}px;
  cursor: default;
  user-select: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: ${e=>zl[e.$size].gap}px;
  outline: none;
  border: 1px solid transparent;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  flex-shrink: 1;

  ${e=>e.$variant==="default"&&it`
    background: ${e.$isPressed?J.bg.active:e.$isHovered?J.bg.hover:J.bg.surface};
    border-color: ${J.border.default};
    color: ${J.text.primary};
    box-shadow: ${J.shadow.xs};
  `}

  ${e=>e.$variant==="primary"&&it`
    background: ${e.$isPressed?J.accent.primaryActive:e.$isHovered?J.accent.primaryHover:J.accent.primary};
    color: ${J.text.inverse};
    border-color: rgba(0, 0, 0, 0.15);
    box-shadow:
      0 1px 3px rgba(180, 90, 30, 0.35),
      0 2px 6px rgba(180, 90, 30, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  `}

  ${e=>e.$variant==="black"&&it`
    background: ${e.$isPressed?J.accent.blackActive:e.$isHovered?J.accent.blackHover:J.accent.black};
    color: ${J.text.inverse};
    border-color: rgba(0, 0, 0, 0.2);
    box-shadow:
      0 1px 3px rgba(15, 12, 8, 0.25),
      0 2px 6px rgba(15, 12, 8, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  `}

  ${e=>e.$variant==="blue"&&it`
    background: ${e.$isPressed?J.accent.secondaryActive:e.$isHovered?J.accent.secondaryHover:J.accent.secondary};
    color: ${J.text.inverse};
    border-color: rgba(0, 0, 0, 0.12);
    box-shadow:
      0 1px 2px rgba(90, 139, 187, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  `}

  ${e=>e.$variant==="ghost"&&it`
    background: ${e.$isPressed?J.bg.active:e.$isHovered?J.bg.hover:"transparent"};
    color: ${J.text.secondary};
  `}

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  position: relative;
`,xN=si`
  0%, 80%, 100% { opacity: 0.25; transform: scale(0.75); }
  40% { opacity: 1; transform: scale(1); }
`,kN=Se.div`
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: ${e=>e.$dotSize*.75}px;

  & > span {
    width: ${e=>e.$dotSize}px;
    height: ${e=>e.$dotSize}px;
    border-radius: 50%;
    background: currentColor;
    animation: ${xN} 1.2s ease-in-out infinite;
  }
